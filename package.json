{
    "name": "ai-to-ui-figma-plugin",
    "version": "1.0.0",
    "description": "Figma plugin to generate native UI elements from AI-generated JSON",
    "main": "dist/code.js",
    "scripts": {
        "build": "npm run build:ui && npm run build:code",
        "build:ui": "node -e \"require('fs').copyFileSync('src/ui.html', 'dist/ui.html')\"",
        "build:code": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es2017 --sourcemap",
        "watch": "npm run build:ui && esbuild src/code.ts --bundle --outfile=dist/code.js --target=es2017 --watch",
        "dev": "npm run watch",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "keywords": [
        "figma",
        "plugin",
        "ai",
        "ui",
        "design"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@figma/plugin-typings": "^1.89.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "esbuild": "^0.20.0",
        "eslint": "^8.56.0",
        "prettier": "^3.2.0",
        "typescript": "^5.3.0",
        "vitest": "^1.2.0",
        "zod": "^3.22.0"
    }
}
